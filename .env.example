# subtitle-studio — environment variables
# Copy this file to .env and fill in the required values.
# Shell variables take precedence over this file (override=False).

# ── REQUIRED ────────────────────────────────────────────────────────────────

# Anthropic (Claude) API key — required, checked at startup
ANTHROPIC_API_KEY=sk-ant-...

# ── OPTIONAL — Claude model ─────────────────────────────────────────────────

# Claude model used for both detection and translation.
# Equivalent to --model on the command line.
# Default: claude-haiku-4-5-20251001
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── OPTIONAL — branding ─────────────────────────────────────────────────────

# Path to a custom branding.yaml file.
# Default: subtitle_studio/data/branding.yaml (bundled in the package).
# BRANDING_YAML_PATH=/path/to/my-branding.yaml

# ── OPTIONAL — cloud Whisper backend (--backend api) ────────────────────────

# URL of the OpenAI-compatible Whisper endpoint (required with --backend api).
# WHISPER_API_URL=

# API key for the cloud Whisper backend (required with --backend api).
# WHISPER_API_KEY=
